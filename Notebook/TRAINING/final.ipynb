# === 1. Import Library ===
import os
import numpy as np
import cv2
from tensorflow.keras.utils import to_categorical
from sklearn.model_selection import KFold
from tensorflow.keras.applications import MobileNetV2
from tensorflow.keras.models import Model
from tensorflow.keras.layers import GlobalAveragePooling2D, Dense, Dropout
from tensorflow.keras.optimizers import Adam
from tensorflow.keras.callbacks import EarlyStopping, ModelCheckpoint

# === 2. Load Dataset dari Folder ===
path_segar = r"C:\Users\Lenovo\Klasifikasi_ikan\datasets\normalized_output\segar"
path_tidak_segar = r"C:\Users\Lenovo\Klasifikasi_ikan\datasets\normalized_output\tidak_segar"

img_height, img_width = 224, 224

def load_images_from_folder(folder, label):
    images, labels = [], []
    for filename in os.listdir(folder):
        img_path = os.path.join(folder, filename)
        img = cv2.imread(img_path)
        if img is not None:
            img = cv2.resize(img, (img_width, img_height))
            img = img / 255.0  # Normalisasi ke [0–1]
            images.append(img)
            labels.append(label)
    return images, labels

images_segar, labels_segar = load_images_from_folder(path_segar, 0)  # 0 = segar
images_tdk_segar, labels_tdk_segar = load_images_from_folder(path_tidak_segar, 1)  # 1 = tidak segar

# Gabungkan
X_data = np.array(images_segar + images_tdk_segar, dtype="float32")
y_data = np.array(labels_segar + labels_tdk_segar)

# One-hot encoding
y_data = to_categorical(y_data, num_classes=2)

print(f"✅ Dataset siap digunakan")
print(f"Total data: {len(X_data)}")
print(f"Shape X_data: {X_data.shape}")
print(f"Shape y_data: {y_data.shape}")

# === 3. Parameter Terbaik dari Hasil Hyperparameter Tuning ===
best_learning_rate = 0.0001
best_dropout = 0.3
best_batch_size = 16

# === 4. Parameter Umum ===
num_classes = 2
k_folds = 5
epochs = 30

# === 5. Folder Output Final Model ===
output_dir = r"C:\Users\Lenovo\Klasifikasi_ikan\hasil_model\final_model"
os.makedirs(output_dir, exist_ok=True)

# === 6. Inisialisasi K-Fold ===
kf = KFold(n_splits=k_folds, shuffle=True, random_state=42)
acc_per_fold = []
loss_per_fold = []

# === 7. Looping Training per Fold ===
fold_no = 1
for train_index, val_index in kf.split(X_data, y_data):
    print(f"\n==============================")
    print(f"🔹 Final Training Fold {fold_no}/{k_folds}")
    print(f"==============================")

    X_train, X_val = X_data[train_index], X_data[val_index]
    y_train, y_val = y_data[train_index], y_data[val_index]

    # === Model MobileNetV2 ===
    base_model = MobileNetV2(weights='imagenet', include_top=False, input_shape=(img_height, img_width, 3))
    base_model.trainable = False

    x = base_model.output
    x = GlobalAveragePooling2D()(x)
    x = Dropout(best_dropout)(x)
    predictions = Dense(num_classes, activation='softmax')(x)
    model = Model(inputs=base_model.input, outputs=predictions)

    model.compile(
        optimizer=Adam(learning_rate=best_learning_rate),
        loss='categorical_crossentropy',
        metrics=['accuracy']
    )

    # === Callback ===
    checkpoint_path = os.path.join(output_dir, f"final_model_fold_{fold_no}.keras")
    callbacks = [
        EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True),
        ModelCheckpoint(filepath=checkpoint_path, save_best_only=True, monitor='val_accuracy', mode='max')
    ]

    # === Training ===
    history = model.fit(
        X_train, y_train,
        validation_data=(X_val, y_val),
        epochs=epochs,
        batch_size=best_batch_size,
        callbacks=callbacks,
        verbose=1
    )

    # === Evaluasi per Fold ===
    scores = model.evaluate(X_val, y_val, verbose=0)
    print(f"✅ Fold {fold_no} - Akurasi: {scores[1]*100:.2f}% | Loss: {scores[0]:.4f}")

    acc_per_fold.append(scores[1] * 100)
    loss_per_fold.append(scores[0])

    # Simpan fold terakhir untuk evaluasi akhir
    if fold_no == k_folds:
        y_pred_final = model.predict(X_val)
        X_val_final = X_val
        y_val_final = y_val

    fold_no += 1

# === 8. Ringkasan Akhir ===
print("\n==============================")
print("📊 Hasil Final Training (K-Fold)")
print("==============================")
for i in range(k_folds):
    print(f"Fold {i+1}: Akurasi = {acc_per_fold[i]:.2f}%, Loss = {loss_per_fold[i]:.4f}")

print(f"\n🔹 Rata-rata Akurasi: {np.mean(acc_per_fold):.2f}%")
print(f"🔹 Rata-rata Loss: {np.mean(loss_per_fold):.4f}")

# === 9. Simpan Data Evaluasi Akhir ===
np.savez(os.path.join(output_dir, "final_evaluation_data.npz"),
         X_val_final=X_val_final,
         y_val_final=y_val_final,
         y_pred_final=y_pred_final)

print(f"\n✅ Data evaluasi akhir disimpan ke '{output_dir}\\final_evaluation_data.npz'")
print("✅ Model final tiap fold disimpan di folder 'final_model'")
